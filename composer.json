{
  "name": "errorgap/laravel",
  "description": "Laravel integration for Errorgap error tracking.",
  "type": "library",
  "license": "MIT",
  "keywords": ["errorgap", "error-tracking", "exceptions", "monitoring", "laravel"],
  "homepage": "https://gitlab.jgrubbs.net/jGRUBBS/errorgap-laravel",
  "authors": [{ "name": "Errorgap" }],
  "require": {
    "php": "^8.1",
    "errorgap/errorgap": "^0.1 || 0.1.x-dev",
    "illuminate/contracts": "^10.0 || ^11.0",
    "illuminate/support": "^10.0 || ^11.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0 || ^9.0",
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": { "Errorgap\\Laravel\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "Errorgap\\Laravel\\Tests\\": "tests/" }
  },
  "extra": {
    "laravel": {
      "providers": ["Errorgap\\Laravel\\ErrorgapServiceProvider"]
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "repositories": [
    { "type": "path", "url": "../errorgap-php" }
  ],
  "scripts": {
    "test": "phpunit"
  }
}
