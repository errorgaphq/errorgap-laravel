{
  "name": "errorgap/laravel",
  "description": "Laravel integration for Errorgap error tracking.",
  "type": "library",
  "license": "MIT",
  "keywords": ["errorgap", "error-tracking", "exceptions", "monitoring", "laravel"],
  "homepage": "https://github.com/errorgaphq/errorgap-laravel",
  "authors": [{ "name": "Errorgap" }],
  "require": {
    "php": "^8.1",
    "errorgap/errorgap": "^0.2",
    "illuminate/contracts": "^10.0 || ^11.0 || ^12.0 || ^13.0",
    "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0 || ^9.0 || ^10.0 || ^11.0",
    "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0"
  },
  "autoload": {
    "psr-4": { "Errorgap\\Laravel\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "Errorgap\\Laravel\\Tests\\": "tests/" }
  },
  "extra": {
    "laravel": {
      "providers": ["Errorgap\\Laravel\\ErrorgapServiceProvider"]
    }
  },
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "test": "phpunit"
  }
}
